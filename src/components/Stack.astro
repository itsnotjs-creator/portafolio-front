---
const technologies = [
  {
    name: 'Vue.js',
    icon: `
      <path fill="currentColor" d="M12 19.6 3.8 5h3.8L12 12.9 16.4 5h3.8L12 19.6Z" />
      <path fill="currentColor" opacity="0.7" d="M12 15.4 6.9 5h3L12 8.7 14.1 5h3L12 15.4Z" />
    `,
    description: 'Framework progresivo para interfaces reactivas y modernas',
    color: 'from-green-500 to-emerald-600'
  },
  {
    name: 'React',
    icon: `
      <circle cx="12" cy="12" r="1.8" fill="currentColor" />
      <ellipse cx="12" cy="12" rx="8.5" ry="3.5" stroke="currentColor" stroke-width="1.6" fill="none" />
      <ellipse cx="12" cy="12" rx="8.5" ry="3.5" stroke="currentColor" stroke-width="1.6" fill="none" transform="rotate(60 12 12)" />
      <ellipse cx="12" cy="12" rx="8.5" ry="3.5" stroke="currentColor" stroke-width="1.6" fill="none" transform="rotate(120 12 12)" />
    `,
    description: 'Biblioteca líder para construir interfaces de usuario dinámicas',
    color: 'from-blue-500 to-cyan-600'
  },
  {
    name: 'NestJS',
    icon: `
      <path d="M12 3.5 18.5 7.3v9.4L12 20.5 5.5 16.7V7.3L12 3.5Z" stroke="currentColor" stroke-width="1.8" fill="none" stroke-linejoin="round" />
      <path d="M8.5 15.6V8.4l7 7.2V8.4" stroke="currentColor" stroke-width="1.8" fill="none" stroke-linecap="round" stroke-linejoin="round" />
    `,
    description: 'Framework escalable para aplicaciones backend enterprise',
    color: 'from-red-500 to-pink-600'
  },
  {
    name: 'IA',
    icon: `
      <rect x="6.5" y="6.5" width="11" height="11" rx="2.2" stroke="currentColor" stroke-width="1.8" fill="none" />
      <path d="M9.2 2.8v2.4M14.8 2.8v2.4M9.2 18.8v2.4M14.8 18.8v2.4M2.8 9.2h2.4M2.8 14.8h2.4M18.8 9.2h2.4M18.8 14.8h2.4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" />
      <path d="M10 14.8v-5.6h1.1l.9 2.2.9-2.2H14v5.6M10 12.2h3.8" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round" fill="none" />
    `,
    description: 'Implementamos automatización, asistentes y flujos inteligentes potenciados por IA aplicada al negocio.',
    color: 'from-fuchsia-500 to-violet-600'
  },
  {
    name: 'Laravel',
    icon: `
      <path d="M7 7.2 12 4.4l5 2.8v5.6l-5 2.8-5-2.8V7.2Z" stroke="currentColor" stroke-width="1.8" fill="none" stroke-linejoin="round" />
      <path d="M12 4.4v5.4m5-2.6-5 2.6-5-2.6m5 8.2v-5.6" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round" />
      <path d="M7 16.8 4.5 15.3V8.7L7 7.2m10 9.6 2.5-1.5V8.7L17 7.2" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round" />
    `,
    description: 'Construimos productos robustos con Laravel para backends, paneles administrativos y APIs mantenibles.',
    color: 'from-orange-500 to-red-600'
  },
  {
    name: 'Cloud',
    icon: `
      <path d="M8.2 18h8.9a3.4 3.4 0 0 0 .5-6.8 5.7 5.7 0 0 0-10.9-1.6A4.1 4.1 0 0 0 8.2 18Z" stroke="currentColor" stroke-width="1.8" fill="none" stroke-linecap="round" stroke-linejoin="round" />
      <path d="M9.5 14.6 12 12l2.5 2.6M12 12v6" stroke="currentColor" stroke-width="1.8" fill="none" stroke-linecap="round" stroke-linejoin="round" />
    `,
    description: 'Diseñamos infraestructura cloud con despliegues continuos, observabilidad y escalado confiable.',
    color: 'from-sky-500 to-indigo-600'
  }
];

const capabilities = [
  {
    title: 'Arquitecturas Escalables',
    description: 'Diseñamos sistemas preparados para crecer con tu negocio, utilizando microservicios y arquitecturas cloud-native.',
    icon: '📐'
  },
  {
    title: 'Buenas Prácticas',
    description: 'Código limpio, testing exhaustivo y documentación completa siguiendo los estándares de la industria.',
    icon: '✨'
  },
  {
    title: 'Cloud Computing',
    description: 'Desplegamos en AWS, Azure y GCP con CI/CD automatizado para entregas rápidas y confiables.',
    icon: '☁️'
  },
  {
    title: 'Inteligencia Artificial',
    description: 'Integramos ML/AI para análisis predictivo, automatización inteligente y optimización de procesos.',
    icon: '🤖'
  }
];
---

<section class="py-20 bg-gradient-to-b from-slate-950 via-slate-900 to-slate-950 relative overflow-hidden" id="nosotros">
  <!-- Animated background -->
  <div class="absolute inset-0">
    <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-primary-500/5 rounded-full blur-3xl animate-pulse"></div>
    <div class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-purple-500/5 rounded-full blur-3xl animate-pulse" style="animation-delay: 1s;"></div>
  </div>

  <div class="container mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <!-- Section Header -->
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h2 class="text-4xl md:text-5xl font-bold mb-4">
        <span class="bg-gradient-to-r from-white to-slate-400 bg-clip-text text-transparent">
          Tecnologías de
        </span>
        <br />
        <span class="bg-gradient-to-r from-purple-400 to-pink-500 bg-clip-text text-transparent">
          Vanguardia
        </span>
      </h2>
      <p class="text-slate-400 text-lg">
        Utilizamos las mejores herramientas para construir soluciones robustas y escalables
      </p>
    </div>

    <!-- Technologies Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6 mb-20 max-w-6xl mx-auto">
      {technologies.map((tech, index) => (
        <div 
          class="group relative bg-slate-900/50 backdrop-blur-sm border border-slate-800 rounded-2xl p-8 hover:border-slate-700 transition-all duration-500 hover:shadow-2xl hover:shadow-primary-500/10 hover:-translate-y-2"
          style={`animation-delay: ${index * 100}ms`}
        >
          <!-- Gradient overlay -->
          <div class={`absolute inset-0 bg-gradient-to-br ${tech.color} opacity-0 group-hover:opacity-10 rounded-2xl transition-opacity duration-500`}></div>
          
          <!-- Icon -->
          <div class="relative mb-6">
            <div class={`w-20 h-20 bg-gradient-to-br ${tech.color} rounded-2xl flex items-center justify-center shadow-lg shadow-primary-500/20 transform group-hover:scale-110 group-hover:rotate-3 transition-all duration-500`}>
              <svg
                class="w-10 h-10 text-white"
                viewBox="0 0 24 24"
                fill="none"
                xmlns="http://www.w3.org/2000/svg"
                aria-hidden="true"
                set:html={tech.icon}
              />
            </div>
          </div>

          <!-- Content -->
          <div class="relative">
            <h3 class="text-2xl font-bold text-white mb-3 group-hover:text-primary-400 transition-colors duration-300">
              {tech.name}
            </h3>
            <p class="text-slate-400 leading-relaxed">
              {tech.description}
            </p>
          </div>

          <!-- Decorative corner -->
          <div class="absolute top-4 right-4 w-8 h-8 border-t-2 border-r-2 border-primary-500/20 group-hover:border-primary-500/50 transition-colors duration-300"></div>
        </div>
      ))}
    </div>

    <!-- Capabilities Section -->
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-12">
        <h3 class="text-3xl md:text-4xl font-bold mb-4">
          <span class="bg-gradient-to-r from-primary-400 to-purple-500 bg-clip-text text-transparent">
            Lo que nos diferencia
          </span>
        </h3>
      </div>

      <!-- Capabilities Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {capabilities.map((capability, index) => (
          <div 
            class="group relative bg-gradient-to-br from-slate-900/80 to-slate-800/80 backdrop-blur-sm border border-slate-700 rounded-xl p-8 hover:border-primary-500/50 transition-all duration-500 overflow-hidden"
            style={`animation-delay: ${index * 100}ms`}
          >
            <!-- Animated background gradient -->
            <div class="absolute inset-0 bg-gradient-to-br from-primary-500/0 to-purple-500/0 group-hover:from-primary-500/5 group-hover:to-purple-500/5 transition-all duration-500"></div>
            
            <div class="relative flex items-start space-x-4">
              <!-- Icon -->
              <div class="flex-shrink-0">
                <div class="w-14 h-14 bg-gradient-to-br from-primary-500 to-purple-600 rounded-xl flex items-center justify-center text-2xl shadow-lg transform group-hover:scale-110 group-hover:rotate-6 transition-all duration-500">
                  {capability.icon}
                </div>
              </div>

              <!-- Content -->
              <div class="flex-1">
                <h4 class="text-xl font-bold text-white mb-2 group-hover:text-primary-400 transition-colors duration-300">
                  {capability.title}
                </h4>
                <p class="text-slate-400 leading-relaxed">
                  {capability.description}
                </p>
              </div>
            </div>

            <!-- Decorative line -->
            <div class="absolute bottom-0 left-0 right-0 h-1 bg-gradient-to-r from-primary-500 to-purple-600 transform scale-x-0 group-hover:scale-x-100 transition-transform duration-500 origin-left"></div>
          </div>
        ))}
      </div>
    </div>

    <!-- CTA Banner -->
    <div class="mt-20 max-w-4xl mx-auto">
      <div class="relative bg-gradient-to-r from-primary-600 to-purple-600 rounded-2xl p-12 overflow-hidden">
        <!-- Background pattern -->
        <div class="absolute inset-0 opacity-10">
          <div class="absolute inset-0" style="background-image: radial-gradient(circle at 2px 2px, white 1px, transparent 1px); background-size: 32px 32px;"></div>
        </div>

        <div class="relative z-10 text-center">
          <h3 class="text-3xl md:text-4xl font-bold text-white mb-4">
            ¿Listo para transformar tu idea?
          </h3>
          <p class="text-primary-100 text-lg mb-8 max-w-2xl mx-auto">
            Hablemos sobre tu proyecto y descubre cómo podemos ayudarte a alcanzar tus objetivos
          </p>
          <a 
            href="#contacto" 
            class="inline-flex items-center space-x-2 px-8 py-4 bg-white text-primary-600 rounded-lg font-semibold hover:bg-slate-100 transition-all duration-300 hover:scale-105 hover:shadow-2xl"
          >
            <span>Agenda una consulta gratuita</span>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  [style*="animation-delay"] {
    animation: fadeInUp 0.6s ease-out forwards;
    opacity: 0;
  }
</style>
