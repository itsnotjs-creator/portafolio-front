              </div>
              <div>
                <h4 class="text-white font-semibold mb-1">Email</h4>
                <a
                  href="mailto:itsnotjs@gmail.com"
                  class="text-slate-400 hover:text-primary-400 transition-colors duration-300"
                >
                  itsnotjs@gmail.com
                </a>
              </div>
            </div>

