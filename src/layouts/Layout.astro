---
interface Props {
  title?: string;
  description?: string;
  image?: string;
  url?: string;
}

const {
  title = "Apirexlab | Desarrollo de Software a Medida y Soluciones Cloud",
  description = "En Apirexlab transformamos ideas en productos digitales escalables. Especialistas en Vue, React, NestJS, Laravel, IA aplicada y arquitectura cloud.",
  image = "/images/og-image.jpg",
  url = "https://www.apirex.cl",
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site || url);
const keywords =
  "apirexlab, desarrollo software, programación web, Vue.js, React, NestJS, Laravel, inteligencia artificial, cloud computing, desarrollo aplicaciones, transformación digital, desarrollo a medida";
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, canonicalURL)} />
    <meta property="og:locale" content="es_ES" />
    <meta property="og:site_name" content="Apirexlab" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalURL} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(image, canonicalURL)} />

    <!-- Additional SEO -->
    <meta name="robots" content="index, follow" />
    <meta name="author" content="Apirexlab" />
    <meta name="theme-color" content="#0ea5e9" />

    <title>{title}</title>

    <!-- Structured Data (JSON-LD) -->
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Organization",
        name: "Apirexlab",
        url: url,
        logo: new URL("/favicon.svg", url),
        description: description,
        sameAs: [],
        contactPoint: {
          "@type": "ContactPoint",
          contactType: "Customer Service",
          availableLanguage: ["Spanish"],
        },
        offers: {
          "@type": "Offer",
          category: "Software Development Services",
        },
      })}
    />
  </head>
  <body class="bg-slate-950 text-white antialiased">
    <slot />
  </body>
</html>

<style is:global>
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    overflow-x: hidden;
  }
</style>
