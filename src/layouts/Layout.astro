---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Desarrollo de Software a Medida | Soluciones Digitales Escalables",
  description = "Transformamos tus ideas en realidades digitales con tecnologías de vanguardia. Especialistas en Vue, React, NestJS y Cloud Computing.",
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body class="bg-slate-950 text-white antialiased">
    <slot />
  </body>
</html>

<style is:global>
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    overflow-x: hidden;
  }
</style>
